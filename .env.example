# -----------------------------------------------------------------------------
# SmartHR - Configuração de Variáveis de Ambiente
# -----------------------------------------------------------------------------
# Copie este arquivo para um novo chamado '.env' e preencha os valores abaixo.
# 
# ATENÇÃO: Nunca envie o seu arquivo '.env' para o controle de versão (Git).
# -----------------------------------------------------------------------------

# --- Configuração Azure OpenAI (Obrigatório para Modo Real) ---
# Se deixados vazios ou com 'sk-', o sistema entrará automaticamente no modo MOCK (Simulação).

# Chave de API do recurso Azure OpenAI
AZURE_OPENAI_KEY=sua_chave_aqui

# Endpoint do recurso (Ex: https://seu-recurso.openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://seu-endpoint.openai.azure.com

# Nome do Deployment do modelo (Ex: gpt-4, gpt-4-mini, etc)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Versão da API (Padrão: 2024-02-15-preview)
AZURE_OPENAI_VERSION=2024-02-15-preview

# --- Configurações de Ambiente (Opcional) ---
# Porta onde o backend FastAPI será executado localmente
PORT=8001
